source 'https://rubygems.org'

# Padrino supports Ruby version 2.2.2 and later
ruby '3.2.2'

# Server requirements
gem 'puma'
gem 'rackup'

# Optional JSON codec (faster performance)
# gem 'oj'

# Project requirements
gem 'rake'

# Loads DATABASE_* and other secrets from a (gitignored) .env file in dev/test
gem 'dotenv'

# Component requirements
gem 'sequel'
gem 'pg'

# Secure password hashing for the User model
gem 'bcrypt'

# JSON view templating
gem 'rabl'
gem 'json'

# Test requirements
gem 'rspec', group: 'test'
gem 'rack-test', require: 'rack/test', group: 'test'

# Padrino Stable Gem
gem 'padrino', '0.16.1'
