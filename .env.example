# Copy to .env and fill in your local PostgreSQL credentials.
# .env is gitignored; never commit real secrets.
DATABASE_USER=your_pg_user
DATABASE_PASSWORD=your_pg_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
# DATABASE_POOL=5
# Production database name (development/test names are fixed in config/database.rb)
# DATABASE_NAME=kanban_backend_production
